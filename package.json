{
	"name": "@somehow-digital/website",
	"type": "module",
	"private": true,
	"packageManager": "pnpm@10.33.4",
	"engines": {
		"node": ">=24",
		"pnpm": ">=10"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "wrangler dev",
		"deploy": "wrangler deploy",
		"upload": "wrangler versions upload",
		"prepare": "concurrently --group --prefix-colors 'auto' 'pnpm:prepare:*'",
		"prepare:husky": "husky",
		"prepare:wrangler": "wrangler types",
		"lint": "concurrently --group --prefix-colors 'auto' 'pnpm:lint:*'",
		"lint:eslint": "eslint .",
		"lint:cspell": "cspell --no-progress --no-summary --no-must-find-files .",
		"lint:knip": "knip --no-progress",
		"fix": "concurrently --group --prefix-colors 'auto' 'pnpm:fix:*'",
		"fix:eslint": "eslint --fix .",
		"fix:knip": "knip --fix --no-progress --workspace ."
	},
	"dependencies": {
		"@thasmo/ui": "^1.3.0",
		"astro": "^6.0.0",
		"motion": "^12.40.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.0",
		"@somehow-digital/commitlint-config": "^1.0.0",
		"@somehow-digital/cspell-dictionary": "^2.0.0",
		"@somehow-digital/eslint-config": "^5.0.0",
		"@somehow-digital/typescript-config": "^3.0.0",
		"@types/node": "^24.0.0",
		"@unocss/astro": "^66.6.5",
		"@unocss/preset-web-fonts": "^66.3.3",
		"concurrently": "^9.1.0",
		"cspell": "^10.0.0",
		"eslint": "^10.0.0",
		"husky": "^9.1.7",
		"knip": "^6.0.0",
		"lint-staged": "^17.0.0",
		"typescript": "^6.0.0",
		"unocss": "^66.0.0",
		"vite": "^8.0.1",
		"wrangler": "^4.54.0"
	}
}
