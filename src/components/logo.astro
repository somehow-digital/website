---
const classes = {
	logo: [
		'[--scale:1.25]',
		'relative',
		'm-0',
		'flex',
		'flex-row-reverse',
		'items-center',
		'gap-[0.35em]',
		'font-sans',
		'text-[2.5rem]',
		'font-[450]',
		'leading-[1em]',
		'tracking-[-0.025em]',
		'invisible',
	],
	type: [
		'relative',
		'block',
		'flex-none',
		'-top-[0.09em]',
		'overflow-x-clip',
	],
	phrase: ['block'],
	mark: [
		'flex',
		'flex-row',
		'flex-none',
		'items-center',
		'gap-[0.05em]',
		'aspect-square',
	],
	bar: [
		'block',
		'm-0',
		'p-0',
		'w-[calc(0.25em*var(--scale))]',
		'bg-current',
		'rounded-[0.025em]',
		'origin-bottom',
	],
};
---
<h1 class:list={classes.logo} data-logo>
	<span class:list={classes.type}>
		<span class:list={classes.phrase} data-logo-type>somehow</span>
		<span class:list={classes.phrase} data-logo-type>digital<span data-logo-dot>.</span></span>
	</span>

	<span class:list={classes.mark} aria-hidden="true" data-logo-mark>
		<span class:list={[...classes.bar, 'self-end', 'h-4/5']} data-logo-bar></span>
		<span class:list={[...classes.bar, 'h-full']} data-logo-bar></span>
		<span class:list={[...classes.bar, 'self-start', 'h-4/5']} data-logo-bar></span>
		<span class:list={[...classes.bar, 'h-full']} data-logo-bar></span>
		<span class:list={[...classes.bar, 'h-3/5']} data-logo-bar></span>
	</span>
</h1>

<script>
	import { animate, stagger } from 'motion';

	const root = document.querySelector<HTMLElement>('[data-logo]');

	if (root) {
		const bars = Array.from(root.querySelectorAll<HTMLElement>('[data-logo-bar]'));
		const mark = root.querySelector<HTMLElement>('[data-logo-mark]');
		const types = Array.from(root.querySelectorAll<HTMLElement>('[data-logo-type]'));
		const dot = root.querySelector<HTMLElement>('[data-logo-dot]');

		if (bars.length && mark && types.length >= 2 && dot) {
			animate([
				[
					root,
					{ visibility: 'visible' },
					{ duration: 0 },
				],
				[
					bars,
					{
						opacity: [0, 1],
						scaleY: [2, 1],
						y: ['-25%', 0],
					},
					{
						delay: stagger(0.025, { ease: 'easeOut' }),
						duration: 0.25,
						ease: 'easeOut',
					},
				],
				[
					mark,
					{ x: ['50%', 0] },
					{ at: 0.5, duration: 0.5, ease: 'easeInOut' },
				],
				[
					types[0]!,
					{ opacity: [0, 1], x: ['-200%', 0] },
					{ at: 0.5, duration: 0.5, ease: 'easeOut' },
				],
				[
					types[1]!,
					{ opacity: [0, 1], x: ['-125%', 0] },
					{ at: 0.5, duration: 0.5, ease: 'easeOut' },
				],
				[
					dot,
					{ opacity: [0, 1] },
					{ at: 1.25, duration: 0.5, ease: 'easeOut' },
				],
			]);
		}
	}
</script>
